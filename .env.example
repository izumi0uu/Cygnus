# Cygnus console API — local development environment.
#
# Copy to `.env` and edit:   cp .env.example .env
# Loaded by cygnus/api/config.py (Settings, env_prefix CYGNUS_, env_file .env).
# `.env` is git-ignored; this example is the only env file that is tracked.

# --- App environment ---
# development: secret_key auto-generated, CORS allows the Vite dev origin below.
# production:  CYGNUS_SECRET_KEY is REQUIRED (startup fails without it).
CYGNUS_APP_ENV=development

# --- Secret key ---
# Leave unset in development (auto-generated via token_urlsafe on each boot —
# so in-memory sessions/JWT do not survive a restart, which is fine locally).
# Set an explicit value only when you need stable tokens across restarts, or in
# production where it is mandatory.
#CYGNUS_SECRET_KEY=

# --- Default admin seed (the local login bootstrap) ---
# By default NO admin is created and login will 401 until you enable this.
# Set to true to seed one admin on startup from the email/password below.
# Idempotent: if an admin with that email already exists, seeding is skipped.
CYGNUS_SEED_DEFAULT_ADMIN=true
CYGNUS_DEFAULT_ADMIN_EMAIL=admin@cygnus.local
CYGNUS_DEFAULT_ADMIN_PASSWORD=admin123

# --- JWT ---
CYGNUS_JWT_EXPIRE_HOURS=24
CYGNUS_JWT_ALGORITHM=HS256

# --- CORS ---
# Comma-separated list (or a JSON array). Defaults to the Vite dev server
# origins, so the frontend on :5173 can reach the API on :8077.
CYGNUS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
